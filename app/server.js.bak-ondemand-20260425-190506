// ── Past recordings (auto-converted .m4v) ─────────────────────────────────
// A cron on the host converts every fresh .guac to .m4v, so this endpoint
// only needs to list and label what's on disk.
//   {name:"TRAIN-01-20260425-104333", user, date, time, sizeMB, ready, raw}
//   ready = true  → .m4v exists, playable
//   ready = false → only .guac present (still recording, or conversion pending)
app.get('/api/recordings', async (req, res) => {
  try {
    const entries = await readdir(RECORDING_PATH_BASE).catch(() => []);
    const byBase = new Map();
    for (const e of entries) {
      const base = e.replace(/\.mp4$|\.m4v$|\.mp4\.partial$/, '');
      const slot = byBase.get(base) || { name: base };
      if (e.endsWith('.mp4'))                 slot.mp4 = e;
      else if (e.endsWith('.mp4.partial'))    slot.busy = e;
      else if (e.endsWith('.m4v'))            slot.busy = e;
      else if (!e.includes('.'))              slot.guac = e;
      byBase.set(base, slot);
    }
    const out = [];
    for (const [base, slot] of byBase) {
      const m = base.match(/^(.+?)-(\d{8})-(\d{6})$/);
      let stat = null;
      const target = slot.mp4 || slot.guac || base;
      try { stat = await statFs(join(RECORDING_PATH_BASE, target)); } catch (_) {}
      out.push({
        name: base,
        user: m ? m[1] : '?',
        date: m ? `${m[2].slice(0,4)}-${m[2].slice(4,6)}-${m[2].slice(6,8)}` : '?',
        time: m ? `${m[3].slice(0,2)}:${m[3].slice(2,4)}:${m[3].slice(4,6)}` : '?',
        sizeMB: stat ? +(stat.size / 1024 / 1024).toFixed(2) : null,
        ready: !!slot.mp4,
        converting: !!slot.busy,
        m4vUrl: slot.mp4 ? `/media/recordings/${slot.mp4}` : null,
      });
    }
    out.sort((a, b) => (b.name).localeCompare(a.name));
    res.json({ recordings: out });
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// Re-derive in-memory state from Students_Rec membership at startup so the
// flag survives container restarts.
(async () => {
  try {
    const tok = await getGuacAdminToken();
    await ensureRecordingInfra(tok).catch(e => console.warn('[recording] bootstrap warning:', e.message));
    const members = await guacGet(`/api/session/data/mysql/userGroups/${encodeURIComponent(REC_RECORD_GROUP_NAME)}/memberUsers`, tok)
      .catch(() => []);
    const list = Array.isArray(members) ? members : [];
    list.forEach(u => recordingState.set(u, { since: Date.now() }));
    if (recordingState.size) {
      console.log(`[recording] re-derived state for ${recordingState.size} user(s): ${[...recordingState.keys()].join(', ')}`);
    }
  } catch (e) {
    console.warn('[recording] startup derive failed:', e.message);
  }
})();

// ── Feedback store ────────────────────────────────────────────────────────
// Student suggestions / corrections for lab .md content. JSONL file; all
// mutations serialised through a single promise chain. Status updates are
// written as write-temp + atomic rename.
const FEEDBACK_DIR  = join(COURSES_DIR, '.feedback');
const FEEDBACK_FILE = join(FEEDBACK_DIR, 'feedback.jsonl');

let fbChain = Promise.resolve();
function runFb(fn) { const p = fbChain.then(fn, fn); fbChain = p.catch(() => {}); return p; }

async function fbEnsureDir() {
  if (!existsSync(FEEDBACK_DIR)) await mkdir(FEEDBACK_DIR, { recursive: true });
}

async function fbReadAll() {
  await fbEnsureDir();
  if (!existsSync(FEEDBACK_FILE)) return [];
  const raw = await readFile(FEEDBACK_FILE, 'utf8');
  const lines = raw.split('\n').filter(l => l.trim());
  const out = [];
  for (const l of lines) {
    try { out.push(JSON.parse(l)); } catch (_) { /* skip torn lines */ }
  }
  return out;
}

async function fbAppend(record) {
  await fbEnsureDir();
  await appendFile(FEEDBACK_FILE, JSON.stringify(record) + '\n', 'utf8');
}

async function fbRewrite(records) {
  await fbEnsureDir();
  const tmp = FEEDBACK_FILE + '.tmp-' + Date.now() + '-' + randomBytes(4).toString('hex');
  await writeFile(tmp, records.map(r => JSON.stringify(r)).join('\n') + (records.length ? '\n' : ''), 'utf8');
  await rename(tmp, FEEDBACK_FILE);
}

function fbGenId() {
  const ts = new Date().toISOString().replace(/[^0-9]/g, '').slice(0, 14);
  return 'fb_' + ts + '_' + randomBytes(3).toString('hex');
}

// Rate-limit: suppress duplicate posts within 60s (same user+course+comment hash)
const recentPosts = new Map(); // key → expiry
function rateKey(user, course, comment) {
  return `${user}|${course}|${createHash('sha1').update(comment).digest('hex').slice(0, 12)}`;
}

// POST /api/feedback — student submit
app.post('/api/feedback', async (req, res) => {
  try {
    const { course, stepIndex, section, taskNum, incorrectText, user, comment } = req.body || {};
    if (!course || stepIndex === undefined || stepIndex === null || !user || !comment) {
      return res.status(400).json({ error: 'course, stepIndex, user, comment are required' });
    }
    if (typeof comment !== 'string' || comment.trim().length < 3) {
      return res.status(400).json({ error: 'comment too short' });
    }
    // Rate-limit
    const k = rateKey(user, course, comment.trim());
    const now = Date.now();
    for (const [kk, exp] of recentPosts.entries()) if (exp < now) recentPosts.delete(kk);
    if (recentPosts.has(k)) return res.status(429).json({ error: 'Duplicate within 60s — already received' });
    recentPosts.set(k, now + 60000);

    // Look up stepTitle from meta
    let stepTitle = null;
    try {
      const meta = await readMeta(course);
      stepTitle = meta.steps?.[Number(stepIndex)]?.title ?? null;
    } catch (_) { /* course may not exist — record anyway */ }

    const rec = {
      id: fbGenId(),
      course: String(course),
      stepIndex: Number(stepIndex),
      stepTitle,
      section: section ? String(section).slice(0, 300) : null,
      taskNum: taskNum ? String(taskNum).slice(0, 20) : null,
      incorrectText: incorrectText ? String(incorrectText).slice(0, 2000) : null,
      user: String(user).slice(0, 80),
      comment: String(comment).slice(0, 5000),
      originalMarkdown: null,
      status: 'pending',
      reviewer: null,
      reviewNote: null,
      createdAt: Math.floor(Date.now() / 1000),
      reviewedAt: null,
    };
    await runFb(() => fbAppend(rec));
    res.status(201).json(rec);
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// GET /api/feedback?course=&status=
app.get('/api/feedback', async (req, res) => {
  try {
    const { course, status } = req.query;
    const all = await runFb(() => fbReadAll());
    let out = all;
    if (course) out = out.filter(r => r.course === course);
    if (status) out = out.filter(r => r.status === status);
    out.sort((a, b) => b.createdAt - a.createdAt);
    res.json(out);
  } catch (e) {
    res.status(500).json({ error: e.message });
  }
});

// PUT /api/feedback/:id — instructor updates status / note / originalMarkdown
app.put('/api/feedback/:id', async (req, res) => {
  try {
    const { id } = req.params;
    const { status, reviewNote, reviewer, originalMarkdown } = req.body || {};
    if (status && !['pending', 'approved', 'declined'].includes(status)) {
      return res.status(400).json({ error: 'invalid status' });
    }
    const updated = await runFb(async () => {
      const all = await fbReadAll();
      const idx = all.findIndex(r => r.id === id);
      if (idx === -1) throw new Error('not_found');
      if (status) all[idx].status = status;
      if (reviewNote !== undefined) all[idx].reviewNote = reviewNote ? String(reviewNote).slice(0, 2000) : null;
      if (reviewer !== undefined)   all[idx].reviewer   = reviewer   ? String(reviewer).slice(0, 80)   : null;
      if (originalMarkdown !== undefined) all[idx].originalMarkdown = originalMarkdown || null;
      if (status === "pending") all[idx].reviewedAt = null;
      else if (status) all[idx].reviewedAt = Math.floor(Date.now() / 1000);
      await fbRewrite(all);
      return all[idx];
    });
    res.json(updated);
  } catch (e) {
    if (e.message === 'not_found') return res.status(404).json({ error: 'Feedback not found' });
    res.status(500).json({ error: e.message });
  }
});

