// ── Logoff endpoint ───────────────────────────────────────────────────────
// POST /api/logoff { users: ["TRAIN-01", ...] }
// Per user: (1) kill every Guacamole active tunnel owned by that user, and
// (2) create a short-lived admin RDP connection whose initial-program runs
// `logoff <sessionId>` to destroy the Windows session. The client opens
// each returned logoffUrl in a hidden iframe just long enough for the RDP
// to establish + initial-program to run (~8s) — that is what actually
// triggers guacd → RDP → logoff.
async function killGuacTunnelsForUser(user, adminToken) {
  const r = await fetch(`${GUAC_BASE}/api/session/data/mysql/activeConnections`, {
    headers: { 'Guacamole-Token': adminToken },
  });
  if (!r.ok) return 0;
  const active = await r.json();
  const targets = Object.entries(active || {})
    .filter(([, c]) => (c.username || '').toLowerCase() === user.toLowerCase())
    .map(([uuid]) => uuid);
  if (!targets.length) return 0;
  const pr = await fetch(`${GUAC_BASE}/api/session/data/mysql/activeConnections`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', 'Guacamole-Token': adminToken },
    body: JSON.stringify(targets.map(uuid => ({ op: 'remove', path: `/${uuid}` }))),
  });
  return pr.ok ? targets.length : 0;
}

app.post('/api/logoff', async (req, res) => {
  const users = Array.isArray(req.body?.users) ? req.body.users.filter(u => typeof u === 'string' && u) : [];
  if (!users.length) return res.status(400).json({ error: 'users array required' });

  try {
    const adminToken = await getGuacAdminToken();
    const results = [];

    for (const user of users) {
      const out = { user, tunnelsKilled: 0, sessionId: null, logoffUrl: null, error: null };

      try { out.tunnelsKilled = await killGuacTunnelsForUser(user, adminToken); }
      catch (e) { out.error = 'tunnel-kill: ' + e.message; }

      const entry = screenshots.get(user);
      out.sessionId = entry?.sessionId || null;

      if (out.sessionId) {
        try {
          const connBody = {
            name: `logoff-${user}-${Date.now()}`,
            protocol: 'rdp',
            parameters: {
              hostname:      WIN_RDP_HOST,
              port:          '3389',
              username:      WIN_RDP_USER,
              password:      WIN_RDP_PASS,
              security:      'any',
              'ignore-cert': 'true',
              'width':       '800',
              'height':      '600',
              'initial-program': `C:\\Windows\\System32\\cmd.exe /c logoff ${out.sessionId}`,
            },
            attributes: { 'max-connections': '1', 'max-connections-per-user': '1' },
          };
          const createRes = await fetch(
            `${GUAC_BASE}/api/session/data/mysql/connections`,
            { method: 'POST', headers: { 'Content-Type': 'application/json', 'Guacamole-Token': adminToken }, body: JSON.stringify(connBody) }
          );
          if (!createRes.ok) {
            const txt = await createRes.text().catch(() => '');
            out.error = (out.error ? out.error + '; ' : '') + `conn-create ${createRes.status}: ${txt.slice(0, 120)}`;
          } else {
            const conn = await createRes.json();
            shadowConnections.set(conn.identifier, Date.now() + 5 * 60 * 1000); // reuse same 5-min cleanup
            const freshToken = await getGuacAdminToken();
            const clientId = Buffer.from(`${conn.identifier} c mysql`).toString('base64');
            out.logoffUrl = `${GUAC_BASE}/#/client/${encodeURIComponent(clientId)}?token=${encodeURIComponent(freshToken)}`;
          }
        } catch (e) {
          out.error = (out.error ? out.error + '; ' : '') + 'rdp-create: ' + e.message;
        }
      }

      // Drop the screenshot entry so the monitor page stops serving the stale
      // image. If the agent posts once more during the ~12s logoff window we
      // accept the brief flicker — the Windows session dies moments later.
      if (out.logoffUrl || out.tunnelsKilled > 0) {
        screenshots.delete(user);
      }

      console.log(`[logoff] user=${user} sid=${out.sessionId} tunnels=${out.tunnelsKilled} logoff=${!!out.logoffUrl} err=${out.error || 'none'}`);
      results.push(out);
    }

    res.json({ results });
  } catch (e) {
    console.error('[logoff] fatal:', e.message);
    res.status(500).json({ error: e.message });
  }
});

// ── Recording control ─────────────────────────────────────────────────────
// All TRAIN-XX users share one Guacamole connection (Win2025_Students, id 7)
// via the Students userGroup. To record one user's session without recording
// the others we maintain a sibling connection Win2025_Students_Rec — identical
// params plus recording-path / recording-name — and a userGroup Students_Rec
// that has READ on it. Toggling a user's recording on swaps their group from
// Students to Students_Rec; toggling off reverses it. Active tunnel is killed
// either way so the next reconnect picks up the new connection.
//
// On first call we lazily ensure both the recording connection and the
// userGroup exist (idempotent, safe to re-run).
//
// API:
//   POST /api/recording/start { users:[…] } → swap each user into Students_Rec
//   POST /api/recording/stop  { users:[…] } → swap each user back into Students
//   GET  /api/recording                     → users currently in Students_Rec
const RECORDING_PATH_BASE   = process.env.RECORDING_PATH_BASE   || '/var/lib/guacamole/recordings';
const REC_BASE_CONN_NAME    = process.env.REC_BASE_CONN_NAME    || 'Win2025_Students';
const REC_RECORDING_CONN    = process.env.REC_RECORDING_CONN    || 'Win2025_Students_Rec';
const REC_NORMAL_GROUP_NAME = process.env.REC_NORMAL_GROUP_NAME || 'Students';
const REC_RECORD_GROUP_NAME = process.env.REC_RECORD_GROUP_NAME || 'Students_Rec';

const recordingState = new Map(); // user → { since }
let recBootstrapped = false;
let recBootstrapPromise = null;

async function guacGet(path, adminToken) {
  const r = await fetch(`${GUAC_BASE}${path}`, { headers: { 'Guacamole-Token': adminToken } });
  if (!r.ok) throw new Error(`GET ${path} → ${r.status}`);
  return r.json();
}
async function guacJson(method, path, body, adminToken) {
  const r = await fetch(`${GUAC_BASE}${path}`, {
    method,
    headers: { 'Content-Type': 'application/json', 'Guacamole-Token': adminToken },
    body: body === undefined ? undefined : JSON.stringify(body),
  });
  if (!r.ok) {
    const txt = await r.text().catch(() => '');
    throw new Error(`${method} ${path} → ${r.status} ${txt.slice(0, 200)}`);
  }
  if (r.status === 204) return null;
  const t = await r.text();
  return t ? JSON.parse(t) : null;
}

async function findConnByName(name, adminToken) {
  const all = await guacGet('/api/session/data/mysql/connections', adminToken);
  for (const [id, c] of Object.entries(all || {})) {
    if ((c.name || '') === name) return { id, conn: c };
  }
  return null;
}

async function ensureRecordingInfra(adminToken) {
  if (recBootstrapped) return;
  if (recBootstrapPromise) return recBootstrapPromise;
  recBootstrapPromise = (async () => {
    // 1. Find base Win2025_Students connection
    const base = await findConnByName(REC_BASE_CONN_NAME, adminToken);
    if (!base) throw new Error(`base connection "${REC_BASE_CONN_NAME}" not found`);
    // 2. Ensure recording-enabled clone exists
    let rec = await findConnByName(REC_RECORDING_CONN, adminToken);
    if (!rec) {
      const baseParams = await guacGet(`/api/session/data/mysql/connections/${base.id}/parameters`, adminToken);
      const recParams = {
        ...baseParams,
        'recording-path':         RECORDING_PATH_BASE,
        'recording-name':         '${GUAC_USERNAME}-${GUAC_DATE}-${GUAC_TIME}',
        'create-recording-path':  'true',
        'recording-include-keys': 'true',
      };
      const created = await guacJson('POST', '/api/session/data/mysql/connections', {
        name: REC_RECORDING_CONN,
        parentIdentifier: base.conn.parentIdentifier || 'ROOT',
        protocol: base.conn.protocol,
        parameters: recParams,
        attributes: base.conn.attributes || {},
      }, adminToken);
      rec = { id: created.identifier, conn: created };
      console.log(`[recording] created connection ${REC_RECORDING_CONN} (id=${rec.id})`);
    }
    // 3. Ensure Students_Rec userGroup exists + has READ on the recording conn
    let groupExists = true;
    try { await guacGet(`/api/session/data/mysql/userGroups/${encodeURIComponent(REC_RECORD_GROUP_NAME)}`, adminToken); }
    catch (_) { groupExists = false; }
    if (!groupExists) {
      await guacJson('POST', '/api/session/data/mysql/userGroups', {
        identifier: REC_RECORD_GROUP_NAME, attributes: {},
      }, adminToken);
      console.log(`[recording] created userGroup ${REC_RECORD_GROUP_NAME}`);
    }
    // Always (idempotent) ensure READ permission on the recording conn
    await guacJson('PATCH', `/api/session/data/mysql/userGroups/${encodeURIComponent(REC_RECORD_GROUP_NAME)}/permissions`, [
      { op: 'add', path: `/connectionPermissions/${rec.id}`, value: 'READ' },
    ], adminToken).catch(e => {
      // 'already exists' style errors are fine; rethrow others
      if (!/already|exists|conflict/i.test(e.message)) throw e;
    });
    recBootstrapped = true;
  })().finally(() => { recBootstrapPromise = null; });
  return recBootstrapPromise;
}

async function setUserGroupMembership(user, group, op, adminToken) {
  // op: 'add' | 'remove'  — both use `path: "/"` with `value: <user>` for memberUsers
  return guacJson('PATCH', `/api/session/data/mysql/userGroups/${encodeURIComponent(group)}/memberUsers`,
    [{ op, path: '/', value: user }],
    adminToken,
  );
}

async function setRecordingForUser(user, enable, adminToken) {
  await ensureRecordingInfra(adminToken);
  if (enable) {
    await setUserGroupMembership(user, REC_RECORD_GROUP_NAME, 'add',    adminToken).catch(e => { if (!/already|exists|conflict/i.test(e.message)) throw e; });
    await setUserGroupMembership(user, REC_NORMAL_GROUP_NAME, 'remove', adminToken).catch(e => { if (!/not.*found|404/i.test(e.message)) throw e; });
  } else {
    await setUserGroupMembership(user, REC_NORMAL_GROUP_NAME, 'add',    adminToken).catch(e => { if (!/already|exists|conflict/i.test(e.message)) throw e; });
    await setUserGroupMembership(user, REC_RECORD_GROUP_NAME, 'remove', adminToken).catch(e => { if (!/not.*found|404/i.test(e.message)) throw e; });
  }
  let tunnelsKilled = 0;
  try { tunnelsKilled = await killGuacTunnelsForUser(user, adminToken); } catch (_) {}
  if (enable) recordingState.set(user, { since: Date.now() });
  else recordingState.delete(user);
  return { user, enabled: enable, tunnelsKilled };
}

app.post('/api/recording/start', async (req, res) => {
  const users = Array.isArray(req.body?.users) ? req.body.users.filter(u => typeof u === 'string' && u) : [];
  if (!users.length) return res.status(400).json({ error: 'users array required' });
  try {
    const adminToken = await getGuacAdminToken();
    const results = [];
    for (const u of users) {
      try { results.push(await setRecordingForUser(u, true, adminToken)); }
      catch (e) { results.push({ user: u, error: e.message, enabled: false }); }
    }
    console.log(`[recording] start: ${results.map(r => `${r.user}=${r.enabled ? 'OK' : (r.error || 'fail')}`).join(' ')}`);
    res.json({ results });
  } catch (e) { res.status(500).json({ error: e.message }); }
});

