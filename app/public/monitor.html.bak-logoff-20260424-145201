<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>Lab Portal — Student Monitor</title>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #111317; --surface: #1a1d24; --surface2: #22262f;
  --border: #2a2d35; --text: #d0d4de; --text-muted: #6b7280;
  --accent: #00d4aa; --accent2: #5794f2; --danger: #e05c5c;
  --online: #00d4aa; --offline: #e05c5c;
  --radius: 6px;
}
body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; font-size: 14px; display: flex; flex-direction: column; height: 100vh; overflow: hidden; }

/* ── Topbar ── */
.topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 20px; height: 48px; display: flex; align-items: center; gap: 16px; flex-shrink: 0; }
.topbar-title { font-weight: 700; color: var(--accent); font-size: 1rem; }
.topbar-stats { font-size: 0.8rem; color: var(--text-muted); }
.topbar-stats b { color: var(--accent); }
.topbar-right { margin-left: auto; display: flex; gap: 8px; align-items: center; }
.btn { padding: 6px 12px; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface2); color: var(--text); font-size: 0.8rem; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; gap: 4px; }
.btn:hover { background: #2e3240; }
.btn-accent { background: var(--accent); color: #000; border-color: var(--accent); font-weight: 600; }
.btn-accent:hover { background: #00bfa0; }
.btn-shadow  { background: transparent; color: var(--accent); border-color: var(--accent); }
.btn-shadow:hover { background: rgba(0,220,180,.12); }
.refresh-indicator { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); display: inline-block; animation: pulse 2s infinite; }
@keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:0.3; } }

/* ── Grid ── */
.grid-wrap { flex: 1; overflow-y: auto; padding: 16px; }
.grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 12px; }
.empty-msg { color: var(--text-muted); text-align: center; margin-top: 80px; font-size: 0.9rem; }

/* ── Student card ── */
.student-card { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; overflow: hidden; cursor: pointer; transition: border-color 0.15s, box-shadow 0.15s; position: relative; }
.student-card:hover { border-color: var(--accent2); box-shadow: 0 0 0 1px var(--accent2); }
.student-card.offline { opacity: 0.5; }

.card-thumb { width: 100%; aspect-ratio: 16/9; background: #000; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; }
.card-thumb img { width: 100%; height: 100%; object-fit: contain; display: block; }
.card-thumb .no-img { color: var(--text-muted); font-size: 0.75rem; }

.card-footer { padding: 8px 10px; display: flex; align-items: center; gap: 6px; }
.status-dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.status-dot.online  { background: var(--online); box-shadow: 0 0 4px var(--online); }
.status-dot.offline { background: var(--offline); }
.card-username { font-weight: 600; font-size: 0.85rem; flex: 1; }
.card-age { font-size: 0.7rem; color: var(--text-muted); }
.card-actions { display: flex; gap: 4px; }
.card-btn { padding: 3px 7px; font-size: 0.7rem; border-radius: 4px; border: 1px solid var(--border); background: var(--surface2); color: var(--text); cursor: pointer; }
.card-btn:hover { background: #2e3240; }
.card-btn.primary { border-color: var(--accent2); color: var(--accent2); }
.card-btn.primary:hover { background: rgba(87,148,242,.12); }
.card-btn.shadow  { border-color: var(--accent); color: var(--accent); }
.card-btn.shadow:hover { background: rgba(0,220,180,.12); }

/* ── Fullscreen modal ── */
.modal-bg { position: fixed; inset: 0; background: rgba(0,0,0,.85); display: flex; flex-direction: column; align-items: center; justify-content: center; z-index: 100; }
.modal-bg.hidden { display: none; }
.modal-header { display: flex; align-items: center; gap: 12px; margin-bottom: 10px; width: 90vw; max-width: 1400px; }
.modal-username { font-weight: 700; font-size: 1.1rem; color: var(--accent); }
.modal-ts { font-size: 0.8rem; color: var(--text-muted); }
.modal-header-actions { margin-left: auto; display: flex; gap: 8px; }
#modal-img { max-width: 90vw; max-height: 85vh; border-radius: 6px; border: 1px solid var(--border); object-fit: contain; display: block; }

/* ── Guacamole overlay ── */
.guac-overlay { position: fixed; inset: 0; background: #000; z-index: 200; display: flex; flex-direction: column; }
.guac-overlay.hidden { display: none; }
.guac-bar { background: var(--surface); border-bottom: 1px solid var(--border); height: 40px; display: flex; align-items: center; padding: 0 16px; gap: 12px; flex-shrink: 0; }
.guac-bar-title { font-weight: 600; font-size: 0.9rem; color: var(--accent2); }
.guac-bar-note { font-size: 0.75rem; color: var(--text-muted); }
.guac-bar-close { margin-left: auto; }
.guac-bar-close button { padding: 4px 10px; font-size: 0.8rem; border-radius: 4px; border: 1px solid var(--danger); background: transparent; color: var(--danger); cursor: pointer; }
.guac-bar-close button:hover { background: rgba(224,92,92,.12); }
#guac-frame { flex: 1; border: none; width: 100%; }
</style>
</head>
<body>

<div class="topbar">
  <span class="topbar-title">Student Monitor</span>
  <span class="topbar-stats">
    <b id="stat-online">0</b> online &nbsp;·&nbsp; <b id="stat-total">0</b> seen this session
  </span>
  <div class="topbar-right">
    <span class="refresh-indicator" title="Auto-refreshing"></span>
    <span id="refresh-label" style="font-size:0.75rem;color:var(--text-muted)">Refresh: 10s</span>
    <select id="refresh-select" style="background:var(--surface2);border:1px solid var(--border);color:var(--text);border-radius:4px;padding:4px 6px;font-size:0.75rem;">
      <option value="5">5s</option>
      <option value="10" selected>10s</option>
      <option value="20">20s</option>
      <option value="30">30s</option>
    </select>
    <a href="/dashboard.html" class="btn">← Dashboard</a>
    <a href="/instructor.html" class="btn">Manage Courses</a>
  </div>
</div>

<div class="grid-wrap">
  <div class="grid" id="grid">
    <div class="empty-msg" id="empty-msg">Waiting for students to connect…<br><small style="margin-top:6px;display:block">Screenshots appear automatically when the agent runs in each student session.</small></div>
  </div>
</div>

<!-- Screenshot fullscreen modal -->
<div class="modal-bg hidden" id="modal">
  <div class="modal-header">
    <span class="modal-username" id="modal-username"></span>
    <span class="modal-ts" id="modal-ts"></span>
    <div class="modal-header-actions">
      <button class="btn btn-shadow" id="modal-open-shadow">👁 Shadow</button>
      <button class="btn btn-accent" id="modal-open-session">🔌 Session</button>
      <button class="btn" onclick="closeModal()">✕ Close</button>
    </div>
  </div>
  <img id="modal-img" src="" alt="Student screen">
</div>

<!-- Live Guacamole session overlay -->
<div class="guac-overlay hidden" id="guac-overlay">
  <div class="guac-bar">
    <span class="guac-bar-title" id="guac-bar-title"></span>
    <span class="guac-bar-note"></span>
    <div class="guac-bar-close"><button onclick="closeGuac()">✕ Close Session</button></div>
  </div>
  <iframe id="guac-frame" src="about:blank" allow="fullscreen; pointer-lock" allowfullscreen tabindex="0"></iframe>
</div>

<script>
const GUAC_URL   = 'https://lab.training.playsap.us/guacamole/';
const GUAC_PASS  = '123456';

let refreshInterval = 10;
let refreshTimer    = null;
let activeUser      = null;
// username → img element (in card)
const cardImgs = new Map();

async function fetchStatus() {
  const res  = await fetch('/api/screenshots');
  const list = await res.json();
  return list;
}

function ageLabel(ms) {
  if (ms < 15000)  return 'just now';
  if (ms < 60000)  return `${Math.floor(ms/1000)}s ago`;
  if (ms < 3600000) return `${Math.floor(ms/60000)}m ago`;
  return 'long ago';
}

function buildCard(entry) {
  const card = document.createElement('div');
  card.className = `student-card ${entry.online ? '' : 'offline'}`;
  card.dataset.user = entry.user;

  const thumb = document.createElement('div');
  thumb.className = 'card-thumb';
  const img = document.createElement('img');
  img.alt  = entry.user;
  img.src  = `/api/screenshots/${entry.user}?t=${Date.now()}`;
  img.onerror = () => { img.style.display='none'; };
  thumb.appendChild(img);
  cardImgs.set(entry.user, img);

  const footer = document.createElement('div');
  footer.className = 'card-footer';
  footer.innerHTML = `
    <span class="status-dot ${entry.online ? 'online' : 'offline'}"></span>
    <span class="card-username">${entry.user}</span>
    <span class="card-age" data-ts="${entry.ts}">${ageLabel(entry.age)}</span>
    <div class="card-actions">
      <button class="card-btn shadow" onclick="openShadow(event,'${entry.user}')" title="Shadow student's exact session (silent)">👁 Shadow</button>
      <button class="card-btn primary" onclick="openSession(event,'${entry.user}')" title="Connect as student (will disconnect them)">🔌 Session</button>
    </div>`;

  card.appendChild(thumb);
  card.appendChild(footer);
  card.addEventListener('dblclick', () => openModal(entry.user));
  card.addEventListener('click', e => { if (!e.target.closest('.card-actions')) openModal(entry.user); });
  return card;
}

async function refresh() {
  let list;
  try { list = await fetchStatus(); } catch { return; }

  const grid = document.getElementById('grid');
  const emptyMsg = document.getElementById('empty-msg');

  if (!list.length) {
    emptyMsg.style.display = '';
    document.getElementById('stat-online').textContent = 0;
    document.getElementById('stat-total').textContent  = 0;
    return;
  }
  emptyMsg.style.display = 'none';

  const online = list.filter(e => e.online).length;
  document.getElementById('stat-online').textContent = online;
  document.getElementById('stat-total').textContent  = list.length;

  // Add new cards / update existing
  list.forEach(entry => {
    let card = grid.querySelector(`[data-user="${entry.user}"]`);
    if (!card) {
      card = buildCard(entry);
      grid.appendChild(card);
    } else {
      // Refresh image
      const img = cardImgs.get(entry.user);
      if (img) img.src = `/api/screenshots/${entry.user}?t=${Date.now()}`;
      // Update status
      card.className = `student-card ${entry.online ? '' : 'offline'}`;
      const dot = card.querySelector('.status-dot');
      if (dot) { dot.className = `status-dot ${entry.online ? 'online' : 'offline'}`; }
      const age = card.querySelector('.card-age');
      if (age) age.textContent = ageLabel(entry.age);
    }
  });

  // Update modal image if open
  if (activeUser) {
    const mi = document.getElementById('modal-img');
    if (mi) mi.src = `/api/screenshots/${activeUser}?t=${Date.now()}`;
    const mts = document.getElementById('modal-ts');
    const entry = list.find(e => e.user === activeUser);
    if (mts && entry) mts.textContent = ageLabel(entry.age);
  }
}

function openModal(user) {
  activeUser = user;
  document.getElementById('modal-username').textContent = user;
  document.getElementById('modal-img').src = `/api/screenshots/${user}?t=${Date.now()}`;
  document.getElementById('modal').classList.remove('hidden');
  document.getElementById('modal-open-session').onclick = () => { closeModal(); openSession(null, user); };
  document.getElementById('modal-open-shadow').onclick  = () => { closeModal(); openShadow(null, user); };
}

function closeModal() {
  document.getElementById('modal').classList.add('hidden');
  activeUser = null;
}

async function openSession(e, user) {
  if (e) e.stopPropagation();
  closeModal();

  const overlay = document.getElementById('guac-overlay');
  const frame   = document.getElementById('guac-frame');
  const title   = document.getElementById('guac-bar-title');
  const note    = document.querySelector('.guac-bar-note');

  // Show overlay with loading state
  title.textContent = `Connecting to ${user}…`;
  note.textContent  = 'Getting session token…';
  frame.src = 'about:blank';
  overlay.classList.remove('hidden');

  // Get a fresh auth token — this bypasses any cached browser Guacamole session
  // The token is fetched server-side, then injected into the Guacamole URL hash.
  // Guacamole 1.4+ reads #?token=TOKEN and uses it for auth, ignoring cookies.
  try {
    const resp = await fetch(`/api/guac-token/${encodeURIComponent(user)}`);
    const data = await resp.json();

    if (!data.token) {
      // User is not a Guacamole user (e.g. VAS, Administrator from Windows-only sessions)
      title.textContent = `No session: ${user}`;
      note.textContent  = `⚠ "${user}" has no Guacamole account — screenshot monitoring only.`;
      frame.src = 'about:blank';
      return;
    }

    // Token obtained — load Guacamole with it injected in the URL hash.
    // This makes Guacamole use THIS token regardless of what's cached in the browser.
    title.textContent = `Session: ${user}`;
    note.textContent  = 'Live session — student may be aware of your presence';
    frame.src = `${GUAC_URL}#?token=${encodeURIComponent(data.token)}`;

  } catch (err) {
    title.textContent = `Error: ${user}`;
    note.textContent  = `Failed to get session token: ${err.message}`;
    console.error('[monitor] openSession error:', err);
  }
}

function closeGuac() {
  document.getElementById('guac-overlay').classList.add('hidden');
  document.getElementById('guac-frame').src = 'about:blank';
}

// Shadow: silently view the student's exact RDP session (no notification, full control)
// Uses mstsc /shadow:<sessionId> /noconsentprompt /control via a temp Guacamole connection
async function openShadow(e, user) {
  if (e) e.stopPropagation();
  closeModal();

  const overlay = document.getElementById('guac-overlay');
  const frame   = document.getElementById('guac-frame');
  const title   = document.getElementById('guac-bar-title');
  const note    = document.querySelector('.guac-bar-note');

  title.textContent = `Shadowing ${user}…`;
  note.textContent  = 'Requesting shadow session…';
  frame.src = 'about:blank';
  overlay.classList.remove('hidden');

  try {
    const resp = await fetch(`/api/shadow/${encodeURIComponent(user)}`);
    const data = await resp.json();

    if (!resp.ok || !data.url) {
      title.textContent = `Shadow failed: ${user}`;
      note.textContent  = `⚠ ${data.error || 'Unknown error'} — is the screenshot agent running?`;
      frame.src = 'about:blank';
      return;
    }

    title.textContent = `👁 Shadowing ${user} (session ${data.sessionId})`;
    note.textContent  = '🔇 Silent shadow — student has NO notification. Full control active.';
    frame.src = data.url;
    // Auto-focus the iframe so Guacamole captures mouse immediately without requiring a click
    frame.onload = () => { try { frame.contentWindow.focus(); } catch(e) {} frame.focus(); };
    setTimeout(() => frame.focus(), 800);

  } catch (err) {
    title.textContent = `Error: ${user}`;
    note.textContent  = `Failed to start shadow: ${err.message}`;
    console.error('[monitor] openShadow error:', err);
  }
}

function startTimer() {
  if (refreshTimer) clearInterval(refreshTimer);
  refreshTimer = setInterval(refresh, refreshInterval * 1000);
}

document.getElementById('refresh-select').addEventListener('change', e => {
  refreshInterval = parseInt(e.target.value);
  document.getElementById('refresh-label').textContent = `Refresh: ${refreshInterval}s`;
  startTimer();
});

document.addEventListener('keydown', e => {
  if (e.key === 'Escape') { closeModal(); closeGuac(); }
});

// Init
refresh();
startTimer();
</script>
</body>
</html>
