<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<link rel="icon" type="image/svg+xml" href="/favicon.svg">
<title>Lab Portal — Instructor</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg: #111317; --surface: #1a1d24; --surface2: #22262f;
  --border: #2a2d35; --text: #d0d4de; --text-muted: #6b7280;
  --accent: #00d4aa; --accent2: #5794f2; --danger: #e05c5c;
  --radius: 6px;
}
body { background: var(--bg); color: var(--text); font-family: system-ui, sans-serif; font-size: 14px; height: 100vh; display: flex; flex-direction: column; overflow: hidden; }

/* ── Top bar ── */
.topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 20px; height: 48px; display: flex; align-items: center; gap: 12px; flex-shrink: 0; }
.topbar-title { font-weight: 700; color: var(--accent); font-size: 1rem; }
.topbar-sub { color: var(--text-muted); font-size: 0.8rem; }

/* ── Main layout ── */
.main { display: grid; grid-template-columns: 240px 1fr; flex: 1; overflow: hidden; }

/* ── Sidebar ── */
.sidebar { background: var(--surface); border-right: 1px solid var(--border); display: flex; flex-direction: column; overflow: hidden; }
.sidebar-head { padding: 12px; border-bottom: 1px solid var(--border); }
.course-list { flex: 1; overflow-y: auto; }
.course-item { padding: 10px 14px; cursor: pointer; border-left: 3px solid transparent; transition: background 0.15s; }
.course-item:hover { background: var(--surface2); }
.course-item.active { background: var(--surface2); border-left-color: var(--accent); }
.course-item-code { font-weight: 700; color: var(--accent2); font-size: 0.8rem; }
.course-item-title { color: var(--text); font-size: 0.85rem; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

/* ── Detail panel ── */
.detail { overflow-y: auto; padding: 24px; display: flex; flex-direction: column; gap: 20px; }
.detail-empty { color: var(--text-muted); margin: auto; text-align: center; }

/* ── Cards ── */
.card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
.card-title { font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; color: var(--text-muted); margin-bottom: 12px; }

/* ── Course header ── */
.course-header { display: flex; align-items: flex-start; justify-content: space-between; gap: 12px; }
.course-info h2 { font-size: 1.1rem; color: var(--text); }
.course-info .course-desc { color: var(--text-muted); font-size: 0.85rem; margin-top: 4px; }
.btn-row { display: flex; gap: 8px; flex-shrink: 0; }

/* ── Buttons ── */
.btn { padding: 6px 12px; border-radius: var(--radius); border: 1px solid var(--border); background: var(--surface2); color: var(--text); font-size: 0.8rem; cursor: pointer; transition: background 0.15s, border-color 0.15s; }
.btn:hover { background: #2e3240; border-color: #3a3f50; }
.btn-accent { background: var(--accent); color: #000; border-color: var(--accent); font-weight: 600; }
.btn-accent:hover { background: #00bfa0; border-color: #00bfa0; }
.btn-danger { color: var(--danger); border-color: var(--danger); }
.btn-danger:hover { background: rgba(224,92,92,.1); }
.btn-sm { padding: 3px 8px; font-size: 0.75rem; }
.btn-icon { padding: 4px 7px; font-size: 0.8rem; }

/* ── URL card ── */
.url-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.url-display { flex: 1; background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 7px 10px; font-family: monospace; font-size: 0.8rem; color: var(--accent2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
select.train-select { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); padding: 5px 8px; font-size: 0.8rem; }
.qr-container { display: none; margin-top: 12px; }
.qr-container.visible { display: block; }
#qr-canvas { border-radius: var(--radius); overflow: hidden; }

/* ── Steps ── */
.step-list { display: flex; flex-direction: column; gap: 6px; }
.step-row { display: flex; align-items: center; gap: 8px; background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 8px 10px; }
.step-num { color: var(--text-muted); font-size: 0.75rem; width: 18px; flex-shrink: 0; }
.step-title { flex: 1; font-size: 0.85rem; }
.step-type { font-size: 0.7rem; padding: 2px 6px; border-radius: 3px; flex-shrink: 0; }
.step-type.file { background: rgba(0,212,170,.15); color: var(--accent); }
.step-type.slug { background: rgba(87,148,242,.15); color: var(--accent2); }
.step-actions { display: flex; gap: 4px; flex-shrink: 0; }

.add-step-row { display: flex; gap: 8px; margin-top: 8px; }

/* ── Modal ── */
.modal-bg { position: fixed; inset: 0; background: rgba(0,0,0,.6); display: flex; align-items: center; justify-content: center; z-index: 100; }
.modal-bg.hidden { display: none; }
.modal { background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 24px; width: 440px; max-width: 95vw; display: flex; flex-direction: column; gap: 16px; }
.modal h3 { font-size: 1rem; color: var(--text); }
.modal-foot { display: flex; justify-content: flex-end; gap: 8px; margin-top: 4px; }

/* ── Form fields ── */
.field { display: flex; flex-direction: column; gap: 6px; }
.field label { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: .04em; }
.field input, .field textarea, .field select { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); color: var(--text); padding: 8px 10px; font-size: 0.85rem; width: 100%; }
.field input:focus, .field textarea:focus { outline: none; border-color: var(--accent2); }
.field textarea { min-height: 80px; resize: vertical; font-family: monospace; }

/* ── Step checkbox ── */
.step-check { width: 15px; height: 15px; accent-color: var(--accent); cursor: pointer; flex-shrink: 0; }
.step-check-all { font-size: 0.7rem; color: var(--accent2); cursor: pointer; text-decoration: none; margin-left: auto; }
.step-check-all:hover { text-decoration: underline; }
.card-title-row { display: flex; align-items: center; }

/* ── Toast ── */
.toast { position: fixed; bottom: 20px; right: 20px; background: var(--surface); border: 1px solid var(--accent); border-radius: var(--radius); padding: 10px 16px; color: var(--accent); font-size: 0.85rem; z-index: 200; opacity: 0; transition: opacity 0.2s; pointer-events: none; }
.toast.show { opacity: 1; }

/* ── Feedback ── */
.fb-badge { display: inline-block; background: var(--danger); color: #fff; font-size: 0.65rem; font-weight: 700; border-radius: 10px; padding: 1px 7px; margin-left: 6px; vertical-align: middle; }
.fb-list { display: flex; flex-direction: column; gap: 6px; }
.fb-empty { color: var(--text-muted); font-size: 0.85rem; padding: 4px 0; }
.fb-row { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 8px 10px; display: flex; flex-direction: column; gap: 4px; cursor: pointer; transition: border-color 0.15s; }
.fb-row:hover { border-color: var(--accent2); }
.fb-row-top { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
.fb-row-title { font-size: 0.85rem; color: var(--text); font-weight: 600; }
.fb-row-meta { font-size: 0.72rem; color: var(--text-muted); }
.fb-row-snippet { font-size: 0.8rem; color: var(--text); opacity: .85; }
.fb-row-snippet code { background: rgba(0,0,0,.35); padding: 1px 5px; border-radius: 3px; font-size: 0.78rem; color: var(--accent2); }
.fb-status-badge { font-size: 0.65rem; padding: 1px 6px; border-radius: 3px; text-transform: uppercase; letter-spacing: .04em; font-weight: 700; }
.fb-status-badge.pending  { background: rgba(87,148,242,.18); color: var(--accent2); }
.fb-status-badge.approved { background: rgba(0,212,170,.15);  color: var(--accent); }
.fb-status-badge.declined { background: rgba(224,92,92,.15);  color: var(--danger); }
.fb-status-badge.stale    { background: rgba(107,114,128,.25); color: var(--text-muted); }
.fb-filter-row { display: flex; gap: 4px; margin-left: auto; }
.fb-filter-row .btn.active { background: var(--accent); color: #000; border-color: var(--accent); }
.fb-review-body { background: var(--surface2); border: 1px solid var(--border); border-radius: var(--radius); padding: 10px 12px; font-size: 0.85rem; white-space: pre-wrap; max-height: 260px; overflow-y: auto; }
.fb-review-body code { background: rgba(0,0,0,.35); padding: 1px 5px; border-radius: 3px; color: var(--accent2); }
.fb-meta-grid { display: grid; grid-template-columns: auto 1fr; gap: 4px 12px; font-size: 0.8rem; }
.fb-meta-grid dt { color: var(--text-muted); font-weight: 600; }
.fb-meta-grid dd { color: var(--text); }

/* ── Grafana embed tile ── */
.gf-tabs { display: flex; gap: 4px; margin-left: auto; align-items: center; }
.gf-tab { padding: 4px 10px; font-size: 0.75rem; border-radius: 4px; border: 1px solid var(--border); background: var(--surface2); color: var(--text); cursor: pointer; }
.gf-tab.active { border-color: var(--accent2); color: var(--accent2); background: rgba(87,148,242,.12); }
.gf-tab:hover { background: #2e3240; }
.gf-frame-wrap { margin-top: 10px; border: 1px solid var(--border); border-radius: 6px; overflow: hidden; background: #000; min-height: 320px; }
.gf-frame-wrap.collapsed { min-height: 0; }
.gf-frame { width: 100%; height: 480px; border: 0; display: block; background: #000; }
.gf-empty { padding: 30px 16px; text-align: center; color: var(--text-muted); font-size: 0.85rem; }
.gf-empty code { background: rgba(0,0,0,.35); padding: 1px 5px; border-radius: 3px; color: var(--accent2); }
.gf-toolbar { display: flex; gap: 4px; }
.gf-toolbar a, .gf-toolbar button { font-size: 0.7rem; padding: 3px 8px; border-radius: 4px; border: 1px solid var(--border); background: var(--surface2); color: var(--text); text-decoration: none; cursor: pointer; }
.gf-toolbar a:hover, .gf-toolbar button:hover { background: #2e3240; }
</style>
</head>
<body>

<div class="topbar">
  <span class="topbar-title">Lab Portal</span>
  <span class="topbar-sub">Instructor Management</span>
</div>

<div class="main">
  <!-- Sidebar -->
  <div class="sidebar">
    <div class="sidebar-head">
      <button class="btn btn-accent" style="width:100%" onclick="openNewCourse()">+ New Course</button>
    </div>
    <div class="course-list" id="course-list"></div>
  </div>

  <!-- Detail -->
  <div class="detail" id="detail">
    <div class="detail-empty">
      <div style="font-size:2rem;margin-bottom:8px">🎓</div>
      <div>Select a course or create a new one</div>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="toast" id="toast"></div>

<!-- Modal: New / Edit Course -->
<div class="modal-bg hidden" id="modal-course">
  <div class="modal">
    <h3 id="modal-course-title">New Course</h3>
    <div class="field"><label>Course Code</label><input id="mc-code" placeholder="e.g. ADM103"></div>
    <div class="field"><label>Title</label><input id="mc-title" placeholder="e.g. ADM 103 — Central User Administration"></div>
    <div class="field"><label>Description</label><input id="mc-desc" placeholder="Short description for instructors"></div>
    <div class="modal-foot">
      <button class="btn" onclick="closeModal('modal-course')">Cancel</button>
      <button class="btn btn-accent" onclick="saveCourse()">Save</button>
    </div>
  </div>
</div>

<!-- Modal: Add HackMD Slug -->
<div class="modal-bg hidden" id="modal-slug">
  <div class="modal">
    <h3>Add HackMD Step</h3>
    <div class="field"><label>Step Title</label><input id="ms-title" placeholder="e.g. Exercise 23 — Operating the CUA"></div>
    <div class="field"><label>HackMD Slug</label><input id="ms-slug" placeholder="e.g. ADM103-EX23"></div>
    <div class="modal-foot">
      <button class="btn" onclick="closeModal('modal-slug')">Cancel</button>
      <button class="btn btn-accent" onclick="saveSlugStep()">Add</button>
    </div>
  </div>
</div>

<!-- Modal: Edit Step Content -->
<div class="modal-bg hidden" id="modal-edit-step">
  <div class="modal" style="width:700px;max-width:95vw">
    <h3 id="modal-edit-step-title">Edit Step</h3>
    <div class="field"><label>Title</label><input id="mes-title"></div>
    <div class="field"><label>Markdown Content</label><textarea id="mes-content" style="min-height:300px"></textarea></div>
    <div class="modal-foot">
      <button class="btn" onclick="closeModal('modal-edit-step')">Cancel</button>
      <button class="btn btn-accent" onclick="saveStepEdit()">Save</button>
    </div>
  </div>
</div>

<!-- Modal: Review Feedback -->
<div class="modal-bg hidden" id="modal-fb-review">
  <div class="modal" style="width:640px;max-width:95vw">
    <h3 id="fb-review-title">Review Feedback</h3>
    <dl class="fb-meta-grid" id="fb-review-meta"></dl>
    <div class="field">
      <label>Paste incorrect text</label>
      <div class="fb-review-body" id="fb-review-incorrect"></div>
    </div>
    <div class="field">
      <label>Student suggestion</label>
      <div class="fb-review-body" id="fb-review-comment"></div>
    </div>
    <div class="field" id="fb-review-note-wrap" style="display:none">
      <label>Reviewer note (optional — shown in Declined / Approved views)</label>
      <textarea id="fb-review-note" rows="2" placeholder="e.g. why declined, or what was changed"></textarea>
    </div>
    <div class="modal-foot">
      <button class="btn" onclick="closeModal('modal-fb-review')">Close</button>
      <button class="btn btn-danger" id="fb-btn-decline">Decline</button>
      <button class="btn" id="fb-btn-approve">Approve as-is</button>
      <button class="btn btn-accent" id="fb-btn-edit">Edit &amp; OK</button>
      <button class="btn btn-danger" id="fb-btn-undo" style="display:none" title="Restore the lab markdown to the snapshot taken before this edit was applied">↶ Undo edit</button>
    </div>
  </div>
</div>

<!-- Modal: QR Code -->
<div class="modal-bg hidden" id="modal-qr">
  <div class="modal" style="align-items:center;text-align:center">
    <h3 id="modal-qr-title">Student QR Code</h3>
    <div id="modal-qr-canvas" style="margin:8px auto"></div>
    <div id="modal-qr-url" style="font-size:0.75rem;color:var(--text-muted);word-break:break-all;margin-top:4px"></div>
    <div class="modal-foot" style="justify-content:center">
      <button class="btn" onclick="closeModal('modal-qr')">Close</button>
    </div>
  </div>
</div>

<script>
const PORTAL_BASE = location.origin;
let courses = [];
let activeLab = null;
let editingCourseMode = false; // 'new' | 'edit'
let editStepIdx = null;

// Feedback state
let fbFilter = 'pending';
let fbRows = [];               // feedback records for the active course, current filter
let fbPendingByCourse = {};    // courseCode → pending count (for sidebar badges)
let activeFeedbackId = null;   // record currently open in the review modal
let pendingFeedbackId = null;  // feedbackId that should auto-approve after saveStepEdit
let pendingFeedbackOriginal = null;

// ── Load ──────────────────────────────────────────────────────────────────
async function loadCourses() {
  const codes = await api('GET', '/api/courses');
  const metas = await Promise.all(codes.map(c => api('GET', `/api/courses/${c}/meta`).then(m => ({ ...m, code: c }))));
  courses = metas;
  renderSidebar();
  if (activeLab) {
    const still = courses.find(c => c.code === activeLab);
    if (still) renderDetail(still); else { activeLab = null; renderDetailEmpty(); }
  }
}

function renderSidebar() {
  const el = document.getElementById('course-list');
  el.innerHTML = courses.map(c => {
    const pending = fbPendingByCourse[c.code] || 0;
    const badge = pending > 0 ? `<span class="fb-badge">${pending}</span>` : '';
    return `
    <div class="course-item ${c.code === activeLab ? 'active' : ''}" onclick="selectCourse('${c.code}')">
      <div class="course-item-code">${c.code}${badge}</div>
      <div class="course-item-title">${c.title}</div>
    </div>`;
  }).join('');
}

function selectCourse(code) {
  activeLab = code;
  renderSidebar();
  renderDetail(courses.find(c => c.code === code));
}

function renderDetailEmpty() {
  document.getElementById('detail').innerHTML = `<div class="detail-empty"><div style="font-size:2rem;margin-bottom:8px">🎓</div><div>Select a course or create a new one</div></div>`;
}

function renderDetail(course) {
  const steps = course.steps || [];
  const userOpts = Array.from({length: 30}, (_,i) => `<option value="TRAIN-${String(i+1).padStart(2,'0')}">TRAIN-${String(i+1).padStart(2,'0')}</option>`).join('');

  document.getElementById('detail').innerHTML = `
    <!-- Header -->
    <div class="card">
      <div class="course-header">
        <div class="course-info">
          <h2>${course.title}</h2>
          <div class="course-desc">${course.description || '<em style="color:var(--text-muted)">No description</em>'}</div>
        </div>
        <div class="btn-row">
          <button class="btn btn-sm" onclick="openEditCourse()">Edit</button>
          <button class="btn btn-sm btn-danger" onclick="deleteCourse()">Delete</button>
        </div>
      </div>
    </div>

    <!-- Student URL -->
    <div class="card">
      <div class="card-title">Student URL</div>
      <div class="url-row">
        <select class="train-select" id="train-select" onchange="updateUrl()">
          ${userOpts}
        </select>
        <div class="url-display" id="url-display"></div>
        <button class="btn btn-sm" onclick="copyUrl()">Copy</button>
        <button class="btn btn-sm" onclick="showQR()">QR</button>
      </div>
    </div>

    <!-- Grafana embed -->
    <div class="card">
      <div class="card-title-row">
        <div class="card-title">Monitoring</div>
        <div class="gf-tabs">
          <button class="gf-tab" data-gf-tab="guacamole" onclick="setGfTab('guacamole')">Guacamole</button>
          <button class="gf-tab" data-gf-tab="rds" onclick="setGfTab('rds')">Win2025 RDS</button>
          <div class="gf-toolbar" style="margin-left:8px">
            <a id="gf-open" href="#" target="_blank" rel="noopener">↗ Open</a>
            <button onclick="reloadGfFrame()" title="Reload dashboard">↻</button>
            <button onclick="openGfConfig()" title="Configure dashboard URLs">⚙</button>
            <button id="gf-toggle" onclick="toggleGfFrame()" title="Hide / show embed">▼</button>
          </div>
        </div>
      </div>
      <div class="gf-frame-wrap" id="gf-frame-wrap">
        <iframe id="gf-frame" class="gf-frame" src="about:blank" allow="fullscreen" referrerpolicy="no-referrer"></iframe>
        <div class="gf-empty" id="gf-empty" style="display:none">
          No dashboard URL configured. Click <code>⚙</code> to set one.<br>
          <small style="color:var(--text-muted)">Tip: in Grafana, copy the dashboard share URL with <code>?kiosk=tv&theme=dark</code> appended.</small>
        </div>
      </div>
    </div>

    <!-- Feedback -->
    <div class="card">
      <div class="card-title-row">
        <div class="card-title">Feedback <span id="fb-count-label"></span></div>
        <div class="fb-filter-row">
          <button class="btn btn-sm active" data-fb-filter="pending" onclick="setFbFilter('pending')">Pending</button>
          <button class="btn btn-sm" data-fb-filter="approved" onclick="setFbFilter('approved')">Approved</button>
          <button class="btn btn-sm" data-fb-filter="declined" onclick="setFbFilter('declined')">Declined</button>
          <button class="btn btn-sm" data-fb-filter="" onclick="setFbFilter('')">All</button>
        </div>
      </div>
      <div class="fb-list" id="fb-list">
        <div class="fb-empty">Loading…</div>
      </div>
    </div>

    <!-- Labs -->
    <div class="card">
      <div class="card-title-row"><div class="card-title">Labs (${steps.length})</div><a class="step-check-all" onclick="toggleAllChecks()">Select all</a></div>
      <div class="step-list" id="step-list">
        ${steps.map((s, i) => stepRow(s, i, steps.length)).join('') || '<div style="color:var(--text-muted);font-size:0.85rem">No steps yet — add one below</div>'}
      </div>
      <div class="add-step-row" style="margin-top:14px">
        <label class="btn btn-sm" style="cursor:pointer">
          + Upload .md
          <input type="file" accept=".md" multiple style="display:none" onchange="uploadMd(this)">
        </label>
        <button class="btn btn-sm" onclick="openSlugModal()">+ HackMD Slug</button>
        <button class="btn btn-sm" onclick="downloadSelected()">⬇ Download ZIP</button>
      </div>
    </div>`;

  updateUrl();
  renderFeedback();
  initGfTile();
}

// ── Grafana embed tile ────────────────────────────────────────────────────
// Two slots: 'guacamole' and 'rds'. URLs persist in localStorage. Each is
// loaded into a single iframe; the active tab dictates which URL.
const GF_KEYS  = { guacamole: 'gfUrl_guacamole', rds: 'gfUrl_rds' };
const GF_LAST  = 'gfActiveTab';
const GF_HIDE  = 'gfHidden';
function gfGetUrl(tab) { try { return localStorage.getItem(GF_KEYS[tab]) || ''; } catch (_) { return ''; } }
function gfSetUrl(tab, url) { try { localStorage.setItem(GF_KEYS[tab], url || ''); } catch (_) {} }
function gfGetTab()       { try { return localStorage.getItem(GF_LAST) || 'guacamole'; } catch (_) { return 'guacamole'; } }
function gfSetTab(t)      { try { localStorage.setItem(GF_LAST, t); } catch (_) {} }
function gfIsHidden()     { try { return localStorage.getItem(GF_HIDE) === '1'; } catch (_) { return false; } }
function gfSetHidden(h)   { try { localStorage.setItem(GF_HIDE, h ? '1' : '0'); } catch (_) {} }

function initGfTile() {
  const tab = gfGetTab();
  setGfTab(tab, /*skipReload*/false);
  applyGfHidden();
}

function setGfTab(tab, skipReload) {
  if (!GF_KEYS[tab]) return;
  gfSetTab(tab);
  document.querySelectorAll('.gf-tab[data-gf-tab]').forEach(b => b.classList.toggle('active', b.dataset.gfTab === tab));
  const url = gfGetUrl(tab);
  const frame = document.getElementById('gf-frame');
  const empty = document.getElementById('gf-empty');
  const open  = document.getElementById('gf-open');
  if (open) open.href = url || '#';
  if (open) open.style.pointerEvents = url ? '' : 'none';
  if (open) open.style.opacity = url ? '' : '0.4';
  if (!url) {
    if (frame) { frame.style.display = 'none'; frame.src = 'about:blank'; }
    if (empty) empty.style.display = 'block';
    return;
  }
  if (empty) empty.style.display = 'none';
  if (frame) {
    frame.style.display = '';
    if (!skipReload) frame.src = url;
  }
}

function reloadGfFrame() {
  const tab = gfGetTab();
  const url = gfGetUrl(tab);
  const f = document.getElementById('gf-frame');
  if (!f || !url) return;
  // Re-assigning forces a refetch even if URL unchanged
  f.src = 'about:blank';
  setTimeout(() => { f.src = url; }, 50);
}

function openGfConfig() {
  const tab   = gfGetTab();
  const cur   = gfGetUrl(tab);
  const label = tab === 'guacamole' ? 'Guacamole' : 'Win2025 RDS';
  const next  = prompt(
    `Grafana dashboard URL for ${label}\n\n`
    + `Tip: append ?kiosk=tv&theme=dark for a clean embed.\n`
    + `Leave blank to clear.`,
    cur,
  );
  if (next === null) return; // cancelled
  gfSetUrl(tab, next.trim());
  setGfTab(tab);
  toast(next.trim() ? `${label} dashboard set` : `${label} dashboard cleared`);
}

function toggleGfFrame() {
  gfSetHidden(!gfIsHidden());
  applyGfHidden();
}

function applyGfHidden() {
  const wrap = document.getElementById('gf-frame-wrap');
  const btn  = document.getElementById('gf-toggle');
  if (!wrap || !btn) return;
  const hidden = gfIsHidden();
  wrap.style.display = hidden ? 'none' : '';
  btn.textContent = hidden ? '▲' : '▼';
  btn.title = hidden ? 'Show embed' : 'Hide embed';
}

function stepRow(step, i, total) {
  const typeLabel = step.file ? 'file' : 'slug';
  return `
    <div class="step-row" id="step-row-${i}">
      <input type="checkbox" class="step-check" data-idx="${i}">
      <span class="step-num">${i+1}</span>
      <span class="step-title">${step.title}</span>
      <span class="step-type ${typeLabel}">${typeLabel}</span>
      <div class="step-actions">
        <button class="btn btn-icon" title="Move up" onclick="moveStep(${i},-1)" ${i===0?'disabled':''}>↑</button>
        <button class="btn btn-icon" title="Move down" onclick="moveStep(${i},1)" ${i===total-1?'disabled':''}>↓</button>
        <button class="btn btn-icon" title="Edit" onclick="openEditStep(${i})">✎</button>
        <button class="btn btn-icon btn-danger" title="Delete" onclick="deleteStep(${i})">✕</button>
      </div>
    </div>`;
}

// ── URL helpers ───────────────────────────────────────────────────────────
function getStudentUrl() {
  const user = document.getElementById('train-select')?.value || 'TRAIN-01';
  return `${PORTAL_BASE}/?user=${user}&course=${activeLab}`;
}

function updateUrl() {
  const el = document.getElementById('url-display');
  if (el) el.textContent = getStudentUrl();
}

function copyUrl() {
  navigator.clipboard.writeText(getStudentUrl()).then(() => toast('URL copied!'));
}

function showQR() {
  const url = getStudentUrl();
  document.getElementById('modal-qr-title').textContent = `${activeLab} — Student QR`;
  document.getElementById('modal-qr-url').textContent = url;
  const canvas = document.getElementById('modal-qr-canvas');
  canvas.innerHTML = '';
  new QRCode(canvas, { text: url, width: 220, height: 220, colorLight: '#111317', colorDark: '#00d4aa' });
  openModal('modal-qr');
}

// ── Course CRUD ───────────────────────────────────────────────────────────
function openNewCourse() {
  editingCourseMode = 'new';
  document.getElementById('modal-course-title').textContent = 'New Course';
  document.getElementById('mc-code').value = '';
  document.getElementById('mc-title').value = '';
  document.getElementById('mc-desc').value = '';
  document.getElementById('mc-code').disabled = false;
  openModal('modal-course');
}

function openEditCourse() {
  editingCourseMode = 'edit';
  const c = courses.find(x => x.code === activeLab);
  document.getElementById('modal-course-title').textContent = 'Edit Course';
  document.getElementById('mc-code').value = c.code;
  document.getElementById('mc-code').disabled = true;
  document.getElementById('mc-title').value = c.title;
  document.getElementById('mc-desc').value = c.description || '';
  openModal('modal-course');
}

async function saveCourse() {
  const code = document.getElementById('mc-code').value.trim();
  const title = document.getElementById('mc-title').value.trim();
  const description = document.getElementById('mc-desc').value.trim();
  if (!code || !title) { alert('Code and title are required'); return; }

  if (editingCourseMode === 'new') {
    await api('POST', '/api/courses', { code, title, description });
    activeLab = code;
    toast('Course created');
  } else {
    await api('PUT', `/api/courses/${code}/meta`, { title, description });
    toast('Course updated');
  }
  closeModal('modal-course');
  await loadCourses();
  selectCourse(activeLab || code);
}

async function deleteCourse() {
  if (!confirm(`Delete course "${activeLab}" and all its content?`)) return;
  await api('DELETE', `/api/courses/${activeLab}`);
  activeLab = null;
  toast('Course deleted');
  await loadCourses();
  renderDetailEmpty();
}

// ── Step CRUD ─────────────────────────────────────────────────────────────
async function uploadMd(input) {
  const files = [...input.files];
  if (!files.length) return;
  for (const file of files) {
    const title = file.name.replace(/\.md$/, '');
    const form = new FormData();
    form.append('title', title);
    form.append('file', file);
    await fetch(`/api/courses/${activeLab}/steps`, { method: 'POST', body: form });
  }
  toast(files.length === 1 ? 'Step uploaded' : `${files.length} steps uploaded`);
  input.value = '';
  await loadCourses();
  selectCourse(activeLab);
}

function openSlugModal() {
  document.getElementById('ms-title').value = '';
  document.getElementById('ms-slug').value = '';
  openModal('modal-slug');
}

async function saveSlugStep() {
  const title = document.getElementById('ms-title').value.trim();
  const slug = document.getElementById('ms-slug').value.trim();
  if (!title || !slug) { alert('Title and slug required'); return; }
  await api('POST', `/api/courses/${activeLab}/steps`, { title, slug });
  toast('Step added');
  closeModal('modal-slug');
  await loadCourses();
  selectCourse(activeLab);
}

async function moveStep(idx, dir) {
  const course = courses.find(c => c.code === activeLab);
  const steps = [...course.steps];
  const newIdx = idx + dir;
  if (newIdx < 0 || newIdx >= steps.length) return;
  [steps[idx], steps[newIdx]] = [steps[newIdx], steps[idx]];
  const order = steps.map((_, i) => i);
  // Build new order as indices of the original
  const orig = course.steps;
  const newOrder = steps.map(s => orig.indexOf(s));
  await api('PUT', `/api/courses/${activeLab}/steps/reorder`, { order: newOrder });
  toast('Steps reordered');
  await loadCourses();
  selectCourse(activeLab);
}

async function deleteStep(idx) {
  if (!confirm('Delete this step?')) return;
  await api('DELETE', `/api/courses/${activeLab}/steps/${idx}`);
  toast('Step deleted');
  await loadCourses();
  selectCourse(activeLab);
}

async function openEditStep(idx) {
  const course = courses.find(c => c.code === activeLab);
  const step = course.steps[idx];
  editStepIdx = idx;
  document.getElementById('modal-edit-step-title').textContent = `Edit Step ${idx + 1}`;
  document.getElementById('mes-title').value = step.title;

  let content = '';
  try {
    const res = await fetch(`/api/courses/${activeLab}/step/${idx}`);
    content = await res.text();
  } catch {}
  document.getElementById('mes-content').value = content;
  openModal('modal-edit-step');
}

async function saveStepEdit() {
  const title = document.getElementById('mes-title').value.trim();
  const content = document.getElementById('mes-content').value;
  const course = courses.find(c => c.code === activeLab);
  const step = course.steps[editStepIdx];

  const form = new FormData();
  form.append('title', title);
  // Save as file (convert slug to file if needed)
  const filename = step.file || (step.slug ? step.slug + '.md' : `step-${editStepIdx}.md`);
  const blob = new Blob([content], { type: 'text/markdown' });
  form.append('file', blob, filename);
  await fetch(`/api/courses/${activeLab}/steps/${editStepIdx}`, { method: 'PUT', body: form });

  // If the edit was launched from a feedback review, auto-approve it
  // and snapshot the original markdown so we have a before/after audit.
  if (pendingFeedbackId) {
    try {
      await api('PUT', `/api/feedback/${pendingFeedbackId}`, {
        status: 'approved',
        reviewNote: 'edited and applied',
        originalMarkdown: pendingFeedbackOriginal || null,
      });
    } catch (e) { console.warn('Could not auto-approve feedback:', e); }
    pendingFeedbackId = null;
    pendingFeedbackOriginal = null;
  }

  toast('Step saved');
  closeModal('modal-edit-step');
  await loadCourses();
  selectCourse(activeLab);
}

// ── Zip download + select-all ─────────────────────────────────────────────
function toggleAllChecks() {
  const boxes = document.querySelectorAll('.step-check');
  const allChecked = [...boxes].every(b => b.checked);
  boxes.forEach(b => b.checked = !allChecked);
}

async function downloadSelected() {
  const course = courses.find(c => c.code === activeLab);
  if (!course) return;
  const checked = [...document.querySelectorAll('.step-check:checked')];
  if (!checked.length) { toast('Select at least one lab'); return; }

  const zip = new JSZip();
  for (const box of checked) {
    const idx = parseInt(box.dataset.idx, 10);
    const step = course.steps[idx];
    let content = '';
    try {
      const res = await fetch(`/api/courses/${activeLab}/step/${idx}`);
      content = await res.text();
    } catch {}
    const filename = step.file || (step.slug ? step.slug + '.md' : `lab-${idx + 1}.md`);
    zip.file(filename, content);
  }

  const blob = await zip.generateAsync({ type: 'blob' });
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = `${activeLab}-labs.zip`;
  a.click();
  URL.revokeObjectURL(url);
  toast(`Downloaded ${checked.length} lab${checked.length > 1 ? 's' : ''}`);
}

// ── Modal helpers ─────────────────────────────────────────────────────────
function openModal(id) { document.getElementById(id).classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id).classList.add('hidden'); }
document.addEventListener('keydown', e => { if (e.key === 'Escape') document.querySelectorAll('.modal-bg:not(.hidden)').forEach(m => m.classList.add('hidden')); });

// ── API helper ────────────────────────────────────────────────────────────
async function api(method, url, body) {
  const opts = { method, headers: {} };
  if (body) { opts.body = JSON.stringify(body); opts.headers['Content-Type'] = 'application/json'; }
  const res = await fetch(url, opts);
  if (!res.ok) { const e = await res.json().catch(() => ({})); throw new Error(e.error || res.statusText); }
  return res.json().catch(() => null);
}

// ── Toast ─────────────────────────────────────────────────────────────────
function toast(msg) {
  const el = document.getElementById('toast');
  el.textContent = msg;
  el.classList.add('show');
  setTimeout(() => el.classList.remove('show'), 2000);
}

// ── Feedback ─────────────────────────────────────────────────────────────
function setFbFilter(f) {
  fbFilter = f;
  document.querySelectorAll('[data-fb-filter]').forEach(b => {
    b.classList.toggle('active', b.dataset.fbFilter === f);
  });
  renderFeedback();
}

function fbStatusBadge(status, isStale) {
  if (isStale) return `<span class="fb-status-badge stale">stale</span>`;
  return `<span class="fb-status-badge ${status}">${status}</span>`;
}

function escHtml(s) { return String(s || '').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

function fbRelTime(ts) {
  const sec = Math.floor(Date.now() / 1000) - ts;
  if (sec < 60) return `${sec}s ago`;
  if (sec < 3600) return `${Math.floor(sec / 60)}m ago`;
  if (sec < 86400) return `${Math.floor(sec / 3600)}h ago`;
  return `${Math.floor(sec / 86400)}d ago`;
}

async function renderFeedback() {
  const listEl = document.getElementById('fb-list');
  if (!listEl || !activeLab) return;
  try {
    const q = new URLSearchParams({ course: activeLab });
    if (fbFilter) q.set('status', fbFilter);
    fbRows = await api('GET', `/api/feedback?${q}`);
  } catch (e) {
    listEl.innerHTML = `<div class="fb-empty">Error loading feedback: ${escHtml(e.message)}</div>`;
    return;
  }
  const course = courses.find(c => c.code === activeLab);
  const stepCount = course?.steps?.length || 0;

  // Update count label and sidebar badge for this course
  const pending = fbFilter === 'pending' ? fbRows.length : (fbPendingByCourse[activeLab] || 0);
  const lbl = document.getElementById('fb-count-label');
  if (lbl) lbl.innerHTML = pending > 0 ? `(${pending} pending)` : '';

  if (!fbRows.length) {
    listEl.innerHTML = `<div class="fb-empty">No ${fbFilter || ''} feedback for this course.</div>`;
    return;
  }
  listEl.innerHTML = fbRows.map(r => {
    const isStale = r.stepIndex >= stepCount;
    const title = r.stepTitle || (isStale ? '(step no longer exists)' : `Step ${r.stepIndex + 1}`);
    const incorrect = r.incorrectText ? `<code>${escHtml(r.incorrectText).slice(0, 120)}</code> — ` : '';
    return `
      <div class="fb-row" onclick="viewFeedback('${r.id}')">
        <div class="fb-row-top">
          ${fbStatusBadge(r.status, isStale)}
          <span class="fb-row-title">${escHtml(title)}</span>
          <span class="fb-row-meta">${escHtml(r.section || '')}${r.taskNum ? ' · task ' + escHtml(r.taskNum) : ''} · ${escHtml(r.user)} · ${fbRelTime(r.createdAt)}</span>
        </div>
        <div class="fb-row-snippet">${incorrect}${escHtml((r.comment || '').slice(0, 120))}${r.comment.length > 120 ? '…' : ''}</div>
      </div>`;
  }).join('');
}

async function refreshFeedbackBadges() {
  try {
    const pending = await api('GET', '/api/feedback?status=pending');
    const byCourse = {};
    for (const r of pending) byCourse[r.course] = (byCourse[r.course] || 0) + 1;
    fbPendingByCourse = byCourse;
    renderSidebar();
  } catch (e) { /* non-fatal */ }
}

function viewFeedback(id) {
  const r = fbRows.find(x => x.id === id);
  if (!r) return;
  activeFeedbackId = id;
  const course = courses.find(c => c.code === activeLab);
  const isStale = r.stepIndex >= (course?.steps?.length || 0);

  document.getElementById('fb-review-title').textContent = `Review Feedback — ${r.stepTitle || 'Step ' + (r.stepIndex + 1)}`;
  document.getElementById('fb-review-meta').innerHTML = `
    <dt>Course</dt><dd>${escHtml(r.course)}</dd>
    <dt>Section</dt><dd>${escHtml(r.section || '(none)')}</dd>
    <dt>Task</dt><dd>${escHtml(r.taskNum || '(whole section)')}</dd>
    <dt>User</dt><dd>${escHtml(r.user)}</dd>
    <dt>Submitted</dt><dd>${new Date(r.createdAt * 1000).toLocaleString()}</dd>
    <dt>Status</dt><dd>${fbStatusBadge(r.status, isStale)}${r.reviewNote ? ' · <em>' + escHtml(r.reviewNote) + '</em>' : ''}</dd>
  `;
  document.getElementById('fb-review-incorrect').textContent = r.incorrectText || '(none provided)';
  document.getElementById('fb-review-comment').textContent = r.comment || '';

  // Only show action buttons for pending items
  const showActions = r.status === 'pending' && !isStale;
  // Undo: only for approved items whose edit we snapshotted (Approve-as-is has no snapshot)
  const showUndo = r.status === 'approved' && !!r.originalMarkdown && !isStale;
  document.getElementById('fb-btn-decline').style.display  = showActions ? '' : 'none';
  document.getElementById('fb-btn-approve').style.display  = showActions ? '' : 'none';
  document.getElementById('fb-btn-edit').style.display     = showActions ? '' : 'none';
  document.getElementById('fb-btn-undo').style.display     = showUndo ? '' : 'none';
  document.getElementById('fb-review-note-wrap').style.display = showActions ? '' : 'none';
  document.getElementById('fb-review-note').value = '';

  openModal('modal-fb-review');
}

async function approveFeedback() {
  if (!activeFeedbackId) return;
  const note = document.getElementById('fb-review-note').value.trim() || null;
  await api('PUT', `/api/feedback/${activeFeedbackId}`, { status: 'approved', reviewNote: note });
  toast('Feedback approved');
  closeModal('modal-fb-review');
  activeFeedbackId = null;
  await renderFeedback();
  await refreshFeedbackBadges();
}

async function declineFeedback() {
  if (!activeFeedbackId) return;
  const note = document.getElementById('fb-review-note').value.trim() || null;
  await api('PUT', `/api/feedback/${activeFeedbackId}`, { status: 'declined', reviewNote: note });
  toast('Feedback declined');
  closeModal('modal-fb-review');
  activeFeedbackId = null;
  await renderFeedback();
  await refreshFeedbackBadges();
}

async function editFeedback() {
  if (!activeFeedbackId) return;
  const r = fbRows.find(x => x.id === activeFeedbackId);
  if (!r) return;
  const course = courses.find(c => c.code === activeLab);
  if (!course || r.stepIndex >= course.steps.length) { alert('Target step no longer exists.'); return; }

  // Snapshot the current markdown for the audit trail
  try {
    const res = await fetch(`/api/courses/${activeLab}/step/${r.stepIndex}`);
    pendingFeedbackOriginal = res.ok ? await res.text() : null;
  } catch (e) { pendingFeedbackOriginal = null; }

  pendingFeedbackId = activeFeedbackId;
  closeModal('modal-fb-review');
  await openEditStep(r.stepIndex);

  // Make the feedback comment visible inside the edit modal title for context
  const titleEl = document.getElementById('modal-edit-step-title');
  if (titleEl) titleEl.textContent = `Edit Step ${r.stepIndex + 1} — applying feedback from ${r.user}`;
}

async function undoFeedback() {
  if (!activeFeedbackId) return;
  const r = fbRows.find(x => x.id === activeFeedbackId);
  if (!r) return;
  if (!r.originalMarkdown) { alert('No snapshot — cannot undo this item.'); return; }

  const course = courses.find(c => c.code === activeLab);
  if (!course || r.stepIndex >= course.steps.length) { alert('Target step no longer exists — cannot undo.'); return; }
  const step = course.steps[r.stepIndex];

  if (!confirm(`Restore ${r.stepTitle || 'Step ' + (r.stepIndex + 1)} to the snapshot taken when this feedback was applied?\n\nThe current markdown will be overwritten. The feedback will move back to Pending.`)) return;

  const form = new FormData();
  form.append('title', step.title);
  const filename = step.file || (step.slug ? step.slug + '.md' : `step-${r.stepIndex}.md`);
  form.append('file', new Blob([r.originalMarkdown], { type: 'text/markdown' }), filename);
  const putRes = await fetch(`/api/courses/${r.course}/steps/${r.stepIndex}`, { method: 'PUT', body: form });
  if (!putRes.ok) { alert('Failed to restore markdown: HTTP ' + putRes.status); return; }

  try {
    await api('PUT', `/api/feedback/${activeFeedbackId}`, {
      status: 'pending',
      reviewNote: 'reverted — lab restored to pre-edit snapshot',
    });
  } catch (e) { console.warn('Markdown reverted but feedback status flip failed:', e); }

  toast('Lab restored from snapshot');
  closeModal('modal-fb-review');
  activeFeedbackId = null;
  await loadCourses();
  selectCourse(activeLab);
  await refreshFeedbackBadges();
}

// Wire review-modal buttons — script runs at end of body so elements exist
document.getElementById('fb-btn-approve').addEventListener('click', approveFeedback);
document.getElementById('fb-btn-decline').addEventListener('click', declineFeedback);
document.getElementById('fb-btn-edit').addEventListener('click', editFeedback);
document.getElementById('fb-btn-undo').addEventListener('click', undoFeedback);

// Hook loadCourses to also refresh pending badges
const _origLoadCourses = loadCourses;
loadCourses = async function() {
  await _origLoadCourses.apply(this, arguments);
  await refreshFeedbackBadges();
};

// ── Init ──────────────────────────────────────────────────────────────────
loadCourses();
</script>
